[server]
port = 8080
auth_token = "your-secret-token-here"

[memory]
default_capacity = 50

# ハイライト表示するキーワード（タイトル・説明文・タグを検索、大文字小文字無視）
[display]
highlight_keywords = ["Claude", "Rust", "React"]

[sources.rss]
poll_interval_secs = 300
lookback_days = 3  # 当日を含む過去 N 日分を表示 (0 = 当日のみ)

[[sources.rss.feeds]]
id = "hacker-news"
name = "Hacker News"
url = "https://news.ycombinator.com/rss"
icon = "hn"
# lookback_days = 7  # フィード個別に上書き可能

[[sources.rss.feeds]]
id = "zenn"
name = "Zenn"
url = "https://zenn.dev/feed"
icon = "zenn"

[[sources.rss.feeds]]
id = "qiita"
name = "Qiita"
url = "https://qiita.com/popular-items/feed.atom"
icon = "qiita"

# クリップボード監視（デフォルト有効・3秒間隔・4文字以上で検知）
# [sources.clipboard]
# enabled = true
# poll_interval_secs = 3
# min_chars = 4
# max_items = 10  # ダッシュボードに保持するクリップボードカードの最大枚数

# GitHub コネクタ（Personal Access Token が必要）
# [sources.github]
# token = "ghp_xxxxxxxxxxxx"
# username = "your-github-username"
# poll_interval_secs = 300
# lookback_days = 3

[windows]
startup = false
notifications = true
tray_icon = true
start_hidden = false
